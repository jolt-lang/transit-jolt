#!/bin/bash
# Cross-implementation verification: feed every transit-format exemplar through
# bin/roundtrip, decode the result with transit-clj, and compare semantically
# to the source of truth. Uses transit-format's own transit.verify harness.
set -e
RT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TF_DIR="${TRANSIT_FORMAT_DIR:-$HOME/src/transit-format}"

# Run from transit-format so mvn finds its pom and its relative exemplar paths
# resolve. bin/classpath already appends TF src/test; add this project's src.
cd "$TF_DIR"
CP="$(bash bin/classpath):$RT_DIR/src"
exec java -Xmx1g -cp "$CP" -Dtransit.jolt.rtdir="$RT_DIR" \
  clojure.main -m transit.verify-driver
