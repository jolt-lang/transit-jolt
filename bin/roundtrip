#!/bin/sh
# transit-format compliance entry point: read transit+json on stdin, write on
# stdout, one value at a time, as a persistent process.
#
# jolt's stdin is line-based (read-line blocks on \n) but transit-clj sends
# newline-less values, so bin/framer.py first injects \n delimiters by copying
# bytes verbatim until bracket depth hits zero. See JOLT_BUGS.md (GAP-2).
set -e
cd "$(dirname "$0")/.."
JOLTC="${JOLTC:-$HOME/src/jolt-lang/jolt/bin/joltc}"
python3 bin/framer.py | "$JOLTC" run -m transit.roundtrip "$@"
